    BATCH_SIZE  = 1,      -- Số script xử lý trước khi yield (để 1 để tránh lag/freeze)
    BATCH_WAIT  = 0.2,    -- Giây nghỉ giữa mỗi script (tăng lên để game thở)
    FRAME_BUDGET = 0.03,  -- Ngưỡng yield khung hình (30ms)

    SCAN_SERVICES = {
        "Workspace",
        "ReplicatedStorage",
        "ReplicatedFirst",
        "StarterGui",
        "StarterPack",
