            end

            local lockTask = createTask("LOCK", TaskManager.priorities.LOCK, TaskLock, {})
            addTask(lockTask)
            processTasks()

            TPingTP = false
            return
        end

        if remain == 0 and not isLocked(getBase()) then
            if TPingTP then return end
            TPingTP = true

            if getgenv().TLHUB.SettingFarm.LockPriority then
                cancelTasks("SELL"); cancelTasks("BUY"); cancelTasks("COLLECT"); cancelTasks("WAIT")
