        target = (getgenv().TLHUB and getgenv().TLHUB.SettingFarm and getgenv().TLHUB.SettingFarm.FpsLock and getgenv().TLHUB.SettingFarm.FpsLock[2]) or 60,
        tol = nil,
        window = {},
        lastAdjust = 0,
        tier = 0,
