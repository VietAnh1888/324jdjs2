    local MaxRetries = 3

    local function safeRequest(reqTable, attempt)
        attempt = attempt or 1
        local ok, res = pcall(request, reqTable)
        if not ok or not res.Success or res.StatusCode >= 300 then
            if attempt < MaxRetries then
                task.wait(2 ^ attempt)
                return safeRequest(reqTable, attempt + 1)
            else
                warn((" Request failed after %d tries (%s)"):format(attempt, ok and res.StatusMessage or "pcall error"))
                return nil
            end
        end
        return res
    end

