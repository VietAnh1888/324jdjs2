        setfpscap(getgenv().TLHUB.SettingFarm.FpsLock[2])
    end

    do
        if getgenv().TLHUB.SettingFarm.OpenLuckyBlock then
            local RS  = game:GetService("ReplicatedStorage")
            local Net = RS:WaitForChild("Packages"):WaitForChild("Net")
            local RE_OPEN = Net:WaitForChild("RE/PlotService/Open")
            local Players = game:GetService("Players")
            local LP = Players.LocalPlayer
            local function getMyPlot()
                local plots = workspace:FindFirstChild("Plots")
                if not plots then return nil end
                for _, plot in ipairs(plots:GetChildren()) do
                    local owner = plot:FindFirstChild("Owner")
                    if owner and owner.Value == LP then
                        return plot
                    end
                    local sign = plot:FindFirstChild("PlotSign")
                    local sg   = sign and sign:FindFirstChild("SurfaceGui")
                    local fr   = sg and sg:FindFirstChild("Frame")
                    local lbl  = fr and fr:FindFirstChild("TextLabel")
                    if lbl and type(lbl.Text)=="string" then
                        local me = (LP.DisplayName or LP.Name):lower()
                        if lbl.Text:lower():find(me, 1, true) then return plot end
                    end
                end
            end

            local function openById(plot, id)
                local pods = plot and plot:FindFirstChild("AnimalPodiums")
                local pod = pods and pods:FindFirstChild(tostring(id))
                if not pod then return false end
                local ok = pcall(function()
                    RE_OPEN:FireServer(tonumber(id))
                end)
                return ok
            end

            task.spawn(function()
                task.wait(10)
                while true do
                    local plot = getMyPlot()
                    if plot then
                        for id = 1, 10 do
                            openById(plot, id)
                            task.wait(0.05)
                        end
                    end
                    task.wait(10)
                end
            end)
        end
    end

