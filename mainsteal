                local pa = rootPart:FindFirstChild("PromptAttachment")
                if pa then prompt = pa:FindFirstChildWhichIsA("ProximityPrompt", true) end
            end
            if not prompt then break end

            local maxAttempts = 10
            local success = false
            repeat 
                wait()
                local player = game:GetService("Players").LocalPlayer
                local character = player.Character
                local playerRootPart = character and character:FindFirstChild("HumanoidRootPart")
                if playerRootPart then
                    PathfindTo2(rootPart.CFrame)
