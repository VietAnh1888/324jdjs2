        saved = { webhookPerSec = nil, autoRebirth = nil },
    }

    local function _q(level)
        pcall(function()
            settings().Rendering.QualityLevel = level
        end)
    end

    local function _avg(tbl)
        local s=0
        for i=1,#tbl do s=s+tbl[i] end
        return (#tbl>0) and (s/#tbl) or 0
    end

    local function _applyTier(t)
        local P = getgenv().__TL_PERF
        if t == P.tier then return end
        P.tier = t
        if t == 0 then
            _q(Enum.QualityLevel.Level04)

            pcall(function()
                if P.saved.webhookPerSec then
                    getgenv().TLHUB.WebHook.WebhookSettings.PerSec = P.saved.webhookPerSec
                end
                if P.saved.autoRebirth ~= nil then
                    getgenv().TLHUB.SettingFarm.AutoRebirth = P.saved.autoRebirth
                end
            end)
            P.throttled = false
        elseif t == 1 then
            _q(Enum.QualityLevel.Level03)

            pcall(function()
                local cfg = getgenv().TLHUB
                if cfg and cfg.WebHook and cfg.WebHook.WebhookSettings then
                    if not P.saved.webhookPerSec then P.saved.webhookPerSec = cfg.WebHook.WebhookSettings.PerSec end
                    cfg.WebHook.WebhookSettings.PerSec = math.max( P.saved.webhookPerSec or 5, 15 )
                end
            end)
            P.throttled = true
        else
            _q(Enum.QualityLevel.Level02)

            pcall(function()
                local cfg = getgenv().TLHUB
                if cfg and cfg.WebHook and cfg.WebHook.WebhookSettings then
                    if not P.saved.webhookPerSec then P.saved.webhookPerSec = cfg.WebHook.WebhookSettings.PerSec end
                    cfg.WebHook.WebhookSettings.PerSec = math.max( P.saved.webhookPerSec or 5, 30 )
                end

                if cfg and cfg.SettingFarm then
                    if P.saved.autoRebirth == nil then P.saved.autoRebirth = cfg.SettingFarm.AutoRebirth end
                    cfg.SettingFarm.AutoRebirth = false
                end
            end)
            P.throttled = true
        end
    end

    getgenv().TL_ShouldThrottle = function()
        return (getgenv().__TL_PERF and getgenv().__TL_PERF.throttled) or false
    end

    do
        local old_PathfindTo = PathfindTo
        if type(old_PathfindTo) == "function" then
            function PathfindTo(destination)
                if getgenv().TL_ShouldThrottle() then
                    return
                end
                return old_PathfindTo(destination)
            end
        end

        local old_PathfindTo2 = PathfindTo2
        if type(old_PathfindTo2) == "function" then
            local lastCall = 0
            function PathfindTo2(destination)
                local now = tick()
                if getgenv().TL_ShouldThrottle() and now - lastCall < 2.0 then
                    return
                end
                lastCall = now
                return old_PathfindTo2(destination)
            end
        end

        if type(TaskManager) == "table" then
            local _origProcess = processTasks
            if type(_origProcess) == "function" then
                function processTasks(...)
                    if getgenv().TL_ShouldThrottle() then
                        if not TaskManager.__lastProc or (tick() - TaskManager.__lastProc) > 0.25 then
                            TaskManager.__lastProc = tick()
                            return _origProcess(...)
                        else
                            return
                        end
                    else
                        return _origProcess(...)
                    end
                end
            end
        end
    end

    task.defer(function()
        local P = getgenv().__TL_PERF
        P.tol = math.max(2, math.floor(P.target * 0.05))
        if getgenv().TLHUB and getgenv().TLHUB.SettingFarm and getgenv().TLHUB.SettingFarm.FpsLock and getgenv().TLHUB.SettingFarm.FpsLock[1] then
            pcall(function() setfpscap(P.target) end)
        end

        local last = tick()
        RunService.RenderStepped:Connect(function()
            local now = tick()
            local dt = now - last
            last = now
            local fps = (dt > 0) and (1/dt) or P.target
            table.insert(P.window, fps)
            while #P.window > 120 do table.remove(P.window, 1) end

            if now - P.lastAdjust < 0.75 then return end
            local avg = _avg(P.window)

            if avg < (P.target - P.tol) then
                if P.tier < 2 then _applyTier(P.tier + 1) end
                P.lastAdjust = now
            elseif avg > (P.target + P.tol + 2) then
                if P.tier > 0 then _applyTier(P.tier - 1) end
                P.lastAdjust = now
            end
        end)
    end)

    local TaskManager = {
        currentTask = nil,
        taskQueue = {},
        pausedTasks = {},
        priorities = {
            LOCK = 1,
            SELL = 2,
            BUY = 3,
            COLLECT = 4,
            WAIT = 5
